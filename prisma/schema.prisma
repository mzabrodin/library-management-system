generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum LoanStatus {
  ACTIVE
  RETURNED
}

model Book {
  id        String  @id @default(uuid(4))
  title     String
  author    String
  year      Int
  isbn      String  @unique
  available Boolean @default(true)
  loans     Loan[]
}

model User {
  id           String   @id @default(uuid(4))
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(USER)
  refreshToken String?
  loans        Loan[]
}

model Loan {
  id         String     @id @default(uuid(4))
  userId     String
  bookId     String
  loanDate   DateTime   @default(now())
  returnDate DateTime?
  status     LoanStatus @default(ACTIVE)

  user User @relation(fields: [userId], references: [id])
  book Book @relation(fields: [bookId], references: [id])
}
